# Network / Server Configuration
# Your server's LAN IP or hostname (for external access from other machines)
SERVER_HOSTNAME=192.168.1.50

# Full public gateway URL (optional, takes precedence over SERVER_HOSTNAME)
# PUBLIC_GATEWAY_URL=http://192.168.1.50:8885

# HuggingFace cache directory on the Docker host (outside project directory)
HF_CACHE_HOST_PATH=/path/to/huggingface/cache

# Optional: MCP server Bearer token for authentication
# Leave empty to disable auth
MCP_AUTH_TOKEN=

# Output directory for generated samples (used by scripts)
OUTPUT_DIR=./output
